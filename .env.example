# =============================================================
# DASH TRÁFEGO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com suas chaves
# =============================================================

# ─────────────────────────────────────────────────────────────
# GOOGLE ADS REST API
# Docs: https://developers.google.com/google-ads/api/docs/start
# ─────────────────────────────────────────────────────────────

# Developer Token (obtido no Google Ads > Ferramentas > API Center)
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 credentials (Google Cloud Console > APIs & Serviços > Credenciais)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Refresh token do usuário com acesso à conta Google Ads
# Gerado via OAuth2 flow: https://developers.google.com/google-ads/api/docs/oauth/oauth-desktop
GOOGLE_ADS_REFRESH_TOKEN=

# Customer ID da conta Google Ads (sem traços, ex: 1234567890)
# Use a MCC root para consultar várias sub-contas
GOOGLE_ADS_CUSTOMER_ID=

# Login Customer ID (obrigatório se usar MCC — ID da conta MCC)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Versão da API Google Ads (atual: v19)
GOOGLE_ADS_API_VERSION=v19

# ─────────────────────────────────────────────────────────────
# GOOGLE ANALYTICS 4 (Data API)
# Docs: https://developers.google.com/analytics/devguides/reporting/data/v1
# ─────────────────────────────────────────────────────────────

# Property ID da propriedade GA4 (ex: 123456789)
# Encontrado em: GA4 > Admin > Detalhes da Propriedade
GA4_PROPERTY_ID=

# Service Account — opção A: arquivo JSON (caminho absoluto)
GOOGLE_APPLICATION_CREDENTIALS=

# Service Account — opção B: credenciais inline (recomendado para Vercel)
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────
# META ADS (Graph API) — Para métricas de Alcance e Frequência
# Docs: https://developers.facebook.com/docs/marketing-api
# ─────────────────────────────────────────────────────────────

# Access Token de longa duração do usuário ou System User
META_ACCESS_TOKEN=

# ID da Ad Account Meta (ex: act_123456789)
META_AD_ACCOUNT_ID=

# App ID e App Secret do seu Meta App
META_APP_ID=
META_APP_SECRET=

# Versão da Graph API (atual: v22.0)
META_API_VERSION=v22.0

# ─────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────

# Modo de dados: "mock" usa dados simulados, "real" chama as APIs reais
# Útil para desenvolvimento sem credenciais configuradas
NEXT_PUBLIC_DATA_MODE=mock

# Base URL da aplicação
NEXTAUTH_URL=http://localhost:3000

# Secret para assinar tokens JWT (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=
