# ─── Meta Ads ─────────────────────────────────────────────────────────────────
# Gere em: Meta Business Manager → Configurações → Usuários do Sistema
META_ACCESS_TOKEN=seu_token_de_sistema_aqui
META_AD_ACCOUNT_ID=act_123456789

# ─── Google Ads ───────────────────────────────────────────────────────────────
# Crie em: console.cloud.google.com → APIs → Google Ads API → Credenciais OAuth2
GOOGLE_ADS_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_ADS_REFRESH_TOKEN=1//xxxxx
# Developer token: console.ads.google.com → Centro de API
GOOGLE_ADS_DEVELOPER_TOKEN=xxxx-xxxx
# Customer ID sem hífens (ou com, o cliente aceita os dois)
GOOGLE_ADS_CUSTOMER_ID=1234567890
# Opcional — se usar conta MCC como login
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# Crie Service Account em: console.cloud.google.com → IAM → Service Accounts
# Adicione o e-mail como "Viewer" na propriedade GA4
GA4_PROPERTY_ID=123456789
GA4_CLIENT_EMAIL=minha-sa@meu-projeto.iam.gserviceaccount.com
# Cole a chave PEM completa (com \n no lugar das quebras de linha para Vercel)
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Modo de dados ────────────────────────────────────────────────────────────
# Descomente para forçar dados simulados mesmo com credenciais configuradas:
# NEXT_PUBLIC_DATA_MODE=mock
